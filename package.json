{
  "name": "raceplex",
  "private": true,
  "description": "Open-source lap timing and telemetry analysis for electric skateboards. A fork of Dove's DataViewer.",
  "license": "GPL-3.0-or-later",
  "author": "RacePlex contributors",
  "homepage": "https://github.com/beadon/RacePlex",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beadon/RacePlex.git"
  },
  "bugs": {
    "url": "https://github.com/beadon/RacePlex/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "bun run build:tracks",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:tracks": "node scripts/build-tracks.mjs",
    "check:tracks": "node scripts/build-tracks.mjs --check",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "coverage:summary": "bun scripts/coverage-summary.mjs",
    "i18n:seed": "bun scripts/seed-translations.mjs",
    "typecheck": "tsc -b",
    "verify:import": "node scripts/verify-import.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
